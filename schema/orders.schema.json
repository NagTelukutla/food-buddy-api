{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "order_create_request",
  "description": "API request shape for creating orders (POST /api/orders, checkout). Core order stored in SQLite; delivery_address stored in order_metadata.",
  "type": "object",
  "required": ["customer_name", "phone", "order_type", "items"],
  "properties": {
    "customer_name": { "type": "string", "minLength": 2, "maxLength": 120 },
    "phone": { "type": "string", "minLength": 10, "maxLength": 20 },
    "table_number": { "type": ["string", "null"], "maxLength": 20 },
    "order_type": {
      "type": "string",
      "enum": ["Dine In", "Pickup", "Delivery"]
    },
    "delivery_address": {
      "type": ["string", "null"],
      "maxLength": 500,
      "description": "Required for Delivery orders at checkout"
    },
    "notes": { "type": ["string", "null"], "maxLength": 500 },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["menu_item_id", "quantity"],
        "properties": {
          "menu_item_id": { "type": "integer", "minimum": 1 },
          "quantity": { "type": "integer", "minimum": 1, "maximum": 50 }
        }
      }
    }
  }
}
